            document.getElementById('inspect-word').textContent = wordObj.word;
            document.getElementById('inspect-pos').textContent = wordObj.pos;
            document.getElementById('inspect-definition').textContent = wordObj.def;
            document.getElementById('inspect-sentence').textContent = `"${wordObj.sentence}"`;
            
            const formsWrapper = document.getElementById('inspect-derivatives-wrapper');
            if (wordObj.forms) {
                formsWrapper.classList.remove('hidden');
                document.getElementById('inspect-derivatives').textContent = wordObj.forms;
            } else {
                formsWrapper.classList.add('hidden');
            }

            // Update Mastery toggle button style on Inspector
            updateInspectorMasteryButton(wordId);

            // Display Pane
            document.getElementById('inspector-placeholder').classList.add('hidden');
            document.getElementById('inspector-active').classList.remove('hidden');
        }

