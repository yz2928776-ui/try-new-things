        // Helper to find parent word regardless of inflections present in the text (e.g. improved -> improve)
        function findMatchingWordObject(text) {
            const trimmed = text.trim().toLowerCase();
            // Direct Match
            let match = vocabDataset.find(item => item.word.toLowerCase() === trimmed);
            if (match) return match;

            // Plural/past tense fuzzy match heuristic
            if (trimmed.endsWith('s')) {
                const singular = trimmed.slice(0, -1);
                match = vocabDataset.find(item => item.word.toLowerCase() === singular);
                if (match) return match;
            }
            if (trimmed.endsWith('ed')) {
                const root = trimmed.slice(0, -2);
                match = vocabDataset.find(item => item.word.toLowerCase() === root);
                if (match) return match;
                
                const rootWithE = trimmed.slice(0, -1); // changed improved -> improve
                match = vocabDataset.find(item => item.word.toLowerCase() === rootWithE);
                if (match) return match;
            }
            if (trimmed.endsWith('ies')) {
                const root = trimmed.slice(0, -3) + "y"; // difficulties -> difficulty
                match = vocabDataset.find(item => item.word.toLowerCase() === root);
                if (match) return match;
            }
            return vocabDataset.find(item => trimmed.includes(item.word.toLowerCase()));
        }

        function inspectWordInPassage(wordId) {
