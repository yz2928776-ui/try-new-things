            updateInspectorMasteryButton(appState.selectedWordId);
        }

        function toggleWordMastery(wordId) {
            const index = appState.masteredIds.indexOf(wordId);
            if (index > -1) {
                appState.masteredIds.splice(index, 1);
            } else {
                appState.masteredIds.push(wordId);
            }
            
            // Persist locally
            localStorage.setItem('lexicamp_mastered_ids', JSON.stringify(appState.masteredIds));
            
            // Refresh Master indicators across all views
            updateMasterProgressIndicator();
            updatePassageVisualIndicators();
            renderDictionary();
