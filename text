        function setupQuizQuestions() {
            const container = document.getElementById('quiz-questions-stack');
            container.innerHTML = '';

            // Render select subset of challenges to keep interface highly focused and neat
            quizChallenges.forEach((item, index) => {
                const questionDiv = document.createElement('div');
                questionDiv.className = "p-4 sm:p-5 rounded-xl border border-slate-100 bg-slate-50/50 flex flex-col gap-3";
                
                // Formulate sentence formatting to highlight blank position dynamically
                const displayPhrase = item.phrase.replace("______", `<span class="bg-indigo-100 text-indigo-900 border-b-2 border-indigo-500 font-bold px-2 py-0.5 rounded-sm select-none" id="blank-${index}">_____</span>`);

                questionDiv.innerHTML = `
                    <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">${item.label}</span>
                        <span id="feedback-badge-${index}" class="text-xs font-bold px-2 py-0.5 rounded-full hidden"></span>
                    </div>
                    <p class="text-sm sm:text-base leading-relaxed text-slate-700 font-medium">${displayPhrase}</p>
                    <div class="flex flex-wrap gap-2 mt-2">
                        ${item.options.map(opt => `
                            <button onclick="selectQuizOption(${index}, '${opt}')" id="btn-opt-${index}-${opt}" class="quiz-option-btn-${index} px-4 py-1.5 bg-white border border-slate-200 hover:bg-slate-50 rounded-lg text-xs font-bold text-slate-700 transition-all shadow-sm">
                                ${opt}
                            </button>
                        `).join('')}
                    </div>
                `;

                container.appendChild(questionDiv);
            });
        }

        const userQuizResponses = {};

        function selectQuizOption(index, optionText) {
            userQuizResponses[index] = optionText;

            // Reset active styles on sibling choices
            document.querySelectorAll(`.quiz-option-btn-${index}`).forEach(btn => {
                btn.className = `quiz-option-btn-${index} px-4 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-bold text-slate-700 transition shadow-sm hover:bg-slate-50`;
            });

            // Set active state styling on the selected option
            const activeBtn = document.getElementById(`btn-opt-${index}-${optionText}`);
            if (activeBtn) {
                activeBtn.className = `quiz-option-btn-${index} px-4 py-1.5 bg-indigo-600 border border-indigo-600 rounded-lg text-xs font-bold text-white transition shadow-md shadow-indigo-600/10`;
            }

            // Inline update quiz phrase visual blank instantly
            document.getElementById(`blank-${index}`).textContent = optionText;
        }

        function checkAllQuizAnswers() {
            let correctCount = 0;

            quizChallenges.forEach((item, index) => {
                const badge = document.getElementById(`feedback-badge-${index}`);
                const userVal = userQuizResponses[index];

                badge.classList.remove('hidden');

                if (userVal && userVal.toLowerCase() === item.correct.toLowerCase()) {
                    correctCount++;
                    badge.innerHTML = `<i class="fa-solid fa-check"></i> Correct`;
                    badge.className = "text-xs font-bold px-2.5 py-0.5 rounded-full bg-teal-50 text-teal-700 border border-teal-200";
                } else {
                    badge.innerHTML = `<i class="fa-solid fa-xmark"></i> Incorrect (Ans: ${item.correct})`;
                    badge.className = "text-xs font-bold px-2.5 py-0.5 rounded-full bg-rose-50 text-rose-700 border border-rose-200";
                }
            });

            // Update Global Quiz Score Indicators
            document.getElementById('quiz-score-indicator').textContent = `${correctCount} / ${quizChallenges.length} Correct`;
        }

        function resetQuiz() {
            // Flush state arrays
            for (let key in userQuizResponses) delete userQuizResponses[key];

            quizChallenges.forEach((item, index) => {
                const badge = document.getElementById(`feedback-badge-${index}`);
                badge.classList.add('hidden');
                document.getElementById(`blank-${index}`).textContent = "_____";
            });

            // Reset scores & layout
            document.getElementById('quiz-score-indicator').textContent = `0 / ${quizChallenges.length} Correct`;
            setupQuizQuestions();
        }
    </script>
