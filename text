        function updateMasterProgressIndicator() {
            const count = appState.masteredIds.length;
            document.getElementById('mastered-count-badge').textContent = `${count}/58 Words`;
            
            const percent = Math.min(100, Math.floor((count / 58) * 100));
            document.getElementById('mastered-progress-bar').style.width = `${percent}%`;
        }

        function updatePassageVisualIndicators() {
            const container = document.getElementById('passage-container');
            const spans = container.querySelectorAll('.vocab-word');

            spans.forEach(span => {
                const keyword = span.getAttribute('data-word').toLowerCase();
                const matchedObj = findMatchingWordObject(keyword);
                if (matchedObj) {
                    if (appState.masteredIds.includes(matchedObj.id)) {
                        // Visual styled success tick indicator for fully mastered items
                        span.className = "vocab-word cursor-pointer bg-teal-100 border-b-2 border-teal-600 text-teal-900 font-semibold hover:bg-teal-200 transition px-1 py-0.5 rounded-sm";
                    } else {
                        span.className = "vocab-word cursor-pointer bg-indigo-50 border-b-2 border-indigo-500 text-indigo-900 font-semibold hover:bg-indigo-100 transition px-1 py-0.5 rounded-sm";
                    }
                }
            });
        }

        function speakWord(text) {
            if ('speechSynthesis' in window) {
                // Cancel active utterances to avoid queued lag
                window.speechSynthesis.cancel();
                
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'en-US';
                utterance.rate = 0.9; // clear, comfortable instructional pace
                window.speechSynthesis.speak(utterance);
            }
        }

        function speakSelectedWord() {
            if (!appState.selectedWordId) return;
            const wordObj = vocabDataset.find(w => w.id === appState.selectedWordId);
            if (wordObj) {
                speakWord(wordObj.word);
            }
        }

        function speakCardFront(event) {
            if (event) event.stopPropagation(); // prevent flipping cards on clicking pronunciation
            const currentCard = appState.flashcardsDeck[appState.currentFlashcardIndex];
            if (currentCard) {
                speakWord(currentCard.word);
            }
        }

        function prepareFlashcardDeck() {
            const filter = appState.flashcardDeckFilter;
            
            if (filter === 'all') {
                appState.flashcardsDeck = [...vocabDataset];
            } else if (filter === 'mastered') {
                appState.flashcardsDeck = vocabDataset.filter(w => appState.masteredIds.includes(w.id));
            } else if (filter === 'needs_review') {
                appState.flashcardsDeck = vocabDataset.filter(w => !appState.masteredIds.includes(w.id));
            }

            // Fallback for empty filtered deck
            if (appState.flashcardsDeck.length === 0) {
                appState.flashcardsDeck = [{
                    id: 0,
                    word: "No words found!",
                    pos: "Hint",
                    def: "Please adjust your active study deck filter parameters above.",
                    forms: "",
                    hint: "Keep exploring vocabulary!",
                    sentence: "No context available."
                }];
            }

            appState.currentFlashcardIndex = 0;
            appState.isFlashcardFlipped = false;
            document.getElementById('flashcard-inner').classList.remove('is-flipped');
            
            renderActiveFlashcard();
        }

        function filterFlashcardDeck(val) {
            appState.flashcardDeckFilter = val;
            prepareFlashcardDeck();
        }

        function shuffleFlashcardDeck() {
            // Fisher-Yates Shuffle array
            for (let i = appState.flashcardsDeck.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [appState.flashcardsDeck[i], appState.flashcardsDeck[j]] = [appState.flashcardsDeck[j], appState.flashcardsDeck[i]];
            }
            appState.currentFlashcardIndex = 0;
            appState.isFlashcardFlipped = false;
            document.getElementById('flashcard-inner').classList.remove('is-flipped');
            renderActiveFlashcard();
        }

        function renderActiveFlashcard() {
            if (appState.flashcardsDeck.length === 0) return;
            const currentCard = appState.flashcardsDeck[appState.currentFlashcardIndex];
            
            // Front Elements Mapping
            document.getElementById('card-word-front').textContent = currentCard.word;
            document.getElementById('card-pos-front').textContent = currentCard.pos;
            document.getElementById('card-hint-front').textContent = `"${currentCard.hint}"`;
            
            if (currentCard.forms) {
                document.getElementById('card-forms-front').classList.remove('invisible');
                document.getElementById('card-forms-front').textContent = `Forms: ${currentCard.forms}`;
            } else {
                document.getElementById('card-forms-front').classList.add('invisible');
            }

            // Progress Indicators
            const displayIndex = appState.flashcardsDeck[0].id === 0 ? 0 : appState.currentFlashcardIndex + 1;
            const displayTotal = appState.flashcardsDeck[0].id === 0 ? 0 : appState.flashcardsDeck.length;
            document.getElementById('deck-progress-indicator').textContent = `Card ${displayIndex} / ${displayTotal}`;

            // Check if card is mastered globally
            const isMastered = appState.masteredIds.includes(currentCard.id);
            const statusBadge = document.getElementById('card-status-badge');
            
            if (isMastered) {
                statusBadge.innerHTML = `<i class="fa-solid fa-circle-check"></i> Mastered`;
                statusBadge.className = "text-xs font-bold bg-teal-50 text-teal-700 px-2.5 py-1 rounded-full border border-teal-100";
            } else {
                statusBadge.innerHTML = `<i class="fa-solid fa-star-half-stroke text-amber-500"></i> Reviewing`;
                statusBadge.className = "text-xs font-bold bg-slate-100 text-slate-700 px-2.5 py-1 rounded-full border border-slate-200/50";
            }

            // Back Elements Mapping (No Chinese)
            document.getElementById('card-word-back').textContent = currentCard.word;
            document.getElementById('card-def-back').textContent = currentCard.def;
            
            if (currentCard.forms) {
                document.getElementById('card-forms-back').textContent = `Derivatives & Related Forms: ${currentCard.forms}`;
            } else {
                document.getElementById('card-forms-back').textContent = ``;
            }
        }

        function flipFlashcard() {
            appState.isFlashcardFlipped = !appState.isFlashcardFlipped;
            const inner = document.getElementById('flashcard-inner');
            if (appState.isFlashcardFlipped) {
                inner.classList.add('is-flipped');
            } else {
                inner.classList.remove('is-flipped');
            }
        }

        function prevFlashcard() {
            if (appState.flashcardsDeck.length <= 1) return;
            
            appState.isFlashcardFlipped = false;
            document.getElementById('flashcard-inner').classList.remove('is-flipped');
            
            // Animation timeout before changing text values
            setTimeout(() => {
                appState.currentFlashcardIndex = (appState.currentFlashcardIndex - 1 + appState.flashcardsDeck.length) % appState.flashcardsDeck.length;
                renderActiveFlashcard();
            }, 150);
        }

        function nextFlashcard() {
            if (appState.flashcardsDeck.length <= 1) return;
            
            appState.isFlashcardFlipped = false;
            document.getElementById('flashcard-inner').classList.remove('is-flipped');
            
            setTimeout(() => {
                appState.currentFlashcardIndex = (appState.currentFlashcardIndex + 1) % appState.flashcardsDeck.length;
                renderActiveFlashcard();
            }, 150);
        }

        function markCurrentCardStatus(shouldMarkMastered) {
            const currentCard = appState.flashcardsDeck[appState.currentFlashcardIndex];
            if (!currentCard || currentCard.id === 0) return;

            const isCurrentlyMastered = appState.masteredIds.includes(currentCard.id);

            if (shouldMarkMastered && !isCurrentlyMastered) {
                toggleWordMastery(currentCard.id);
            } else if (!shouldMarkMastered && isCurrentlyMastered) {
                toggleWordMastery(currentCard.id);
            }

            // Auto advance carousel with subtle feedback transition
            nextFlashcard();
        }

        function renderDictionary() {
            const grid = document.getElementById('dictionary-grid');
            grid.innerHTML = '';

            const searchQuery = document.getElementById('dict-search-input').value.toLowerCase().trim();
            const filterPos = document.getElementById('dict-filter-pos').value;

            // Map and filter Dataset
            const filteredWords = vocabDataset.filter(wordObj => {
                const matchesSearch = wordObj.word.toLowerCase().includes(searchQuery) || 
                                     wordObj.forms.toLowerCase().includes(searchQuery);
                
                let matchesPos = true;
                if (filterPos !== 'all') {
                    matchesPos = wordObj.type === filterPos;
                }

                return matchesSearch && matchesPos;
            });

            if (filteredWords.length === 0) {
                grid.innerHTML = `
                    <div class="col-span-1 md:col-span-2 lg:col-span-3 text-center py-12 text-slate-400">
                        <i class="fa-solid fa-spell-check text-4xl mb-3 block"></i>
                        No matching dictionary terms found. Try a different filter or search.
                    </div>
                `;
                return;
            }

            filteredWords.forEach(wordObj => {
                const isMastered = appState.masteredIds.includes(wordObj.id);
                
                const card = document.createElement('div');
                card.className = `p-5 rounded-xl border transition-all flex flex-col justify-between ${
                    isMastered 
                    ? 'border-teal-200 bg-teal-50/10 hover:border-teal-300' 
                    : 'border-slate-200 hover:border-slate-300 bg-white shadow-sm'
                }`;

                card.innerHTML = `
                    <div>
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <span class="bg-indigo-50 text-indigo-700 text-2xs px-2 py-0.5 rounded-md font-bold uppercase tracking-wide mr-2">
                                    ${wordObj.pos}
                                </span>
                                <h4 class="text-lg font-bold text-slate-800 inline-block align-middle">${wordObj.word}</h4>
                            </div>
                            <div class="flex items-center gap-1">
                                <button onclick="speakWord('${wordObj.word}')" class="text-slate-400 hover:text-indigo-600 transition p-1 hover:bg-slate-100 rounded-full" title="Hear Pronunciation">
                                    <i class="fa-solid fa-volume-high text-xs"></i>
                                </button>
                                <button onclick="toggleWordMastery(${wordObj.id})" class="transition p-1.5 rounded-full ${isMastered ? 'text-teal-600' : 'text-slate-300 hover:text-slate-500'}" title="Toggle Mastery Status">
                                    <i class="fa-solid fa-circle-check text-sm"></i>
                                </button>
                            </div>
                        </div>
                        <p class="text-slate-600 text-sm leading-relaxed mb-4">${wordObj.def}</p>
                    </div>
                    <div class="border-t border-slate-100/80 pt-3 mt-auto">
                        <span class="text-slate-400 font-bold text-3xs uppercase tracking-widest block mb-1">Passage Context</span>
                        <p class="text-slate-500 text-xs italic">"${wordObj.hint}"</p>
                    </div>
                `;

                grid.appendChild(card);
            });
        }

        function searchVocabularyDictionary() {
            renderDictionary();
        }

