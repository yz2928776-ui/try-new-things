<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LexiCamp Interactive Vocabulary Hub</title>
    <!-- Tailwind CSS for modern adaptive layouts -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Sans and Inter Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,400&display=swap" rel="stylesheet">
    <!-- FontAwesome for Premium Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        .serif-font {
            font-family: 'Playfair Display', serif;
        }
        /* Custom scrollbar styling for a cleaner look */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* 3D Flashcard Flip Effect */
        .flashcard-perspective {
            perspective: 1200px;
        }
        .flashcard-inner {
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            transform-style: preserve-3d;
        }
        .flashcard-inner.is-flipped {
            transform: rotateY(180deg);
        }
        .flashcard-front, .flashcard-back {
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
        }
        .flashcard-back {
            transform: rotateY(180deg);
        }
    </style>
</head>
<body class="min-height-screen flex flex-col text-slate-800 bg-slate-50/50">

    <header class="bg-indigo-900 text-white shadow-md sticky top-0 z-30">
        <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-teal-400 text-indigo-900 p-2.5 rounded-xl shadow-inner">
                    <i class="fa-solid fa-graduation-cap text-2xl"></i>
                </div>
                <div>
                    <h1 class="text-xl font-extrabold tracking-tight">LexiCamp</h1>
                    <p class="text-xs text-teal-300 font-medium">Interactive Vocabulary Explorer</p>
                </div>
            </div>
            <!-- Global master progress indicator -->
            <div class="flex items-center gap-4 bg-indigo-950/60 px-4 py-2 rounded-full border border-indigo-800/50">
                <div class="text-right">
                    <span class="text-xs text-slate-300 block leading-none">Mastered Progress</span>
                    <span id="mastered-count-badge" class="text-sm font-bold text-teal-400">0/58 Words</span>
                </div>
                <div class="w-24 bg-indigo-900 h-2.5 rounded-full overflow-hidden">
                    <div id="mastered-progress-bar" class="bg-teal-400 h-full w-0 transition-all duration-500"></div>
                </div>
            </div>
        </div>
        <!-- Tab Switcher -->
        <div class="bg-indigo-950/80 border-t border-indigo-800/30">
            <div class="max-w-7xl mx-auto px-4 flex justify-around sm:justify-start gap-1 sm:gap-4 overflow-x-auto">
                <button onclick="switchTab('reader')" id="tab-btn-reader" class="tab-btn px-4 py-3 text-sm font-semibold border-b-2 border-teal-400 text-teal-400 transition-all whitespace-nowrap flex items-center gap-2">
                    <i class="fa-solid fa-book-open"></i> Interactive Reader
                </button>
                <button onclick="switchTab('flashcards')" id="tab-btn-flashcards" class="tab-btn px-4 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white transition-all whitespace-nowrap flex items-center gap-2">
                    <i class="fa-solid fa-clone"></i> 3D Flashcards
                </button>
                <button onclick="switchTab('dictionary')" id="tab-btn-dictionary" class="tab-btn px-4 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white transition-all whitespace-nowrap flex items-center gap-2">
                    <i class="fa-solid fa-spell-check"></i> Lexicon List
                </button>
                <button onclick="switchTab('quiz')" id="tab-btn-quiz" class="tab-btn px-4 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-300 hover:text-white transition-all whitespace-nowrap flex items-center gap-2">
                    <i class="fa-solid fa-circle-question"></i> Cloze Quiz
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-6 flex-grow w-full">
        
        <!-- ==================== TAB: INTERACTIVE READER ==================== -->
        <section id="tab-content-reader" class="tab-pane block">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                <!-- Left: Interactive Text Passage -->
                <div class="lg:col-span-8 bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-slate-200/60">
                    <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-6">
                        <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                            <span class="text-teal-600"><i class="fa-solid fa-book"></i></span>
                            Last Summer at LexiCamp
                        </h2>
                        <span class="text-xs bg-indigo-50 text-indigo-700 px-3 py-1.5 rounded-full font-semibold">
                            <i class="fa-solid fa-circle-info mr-1"></i> Click highlighted words for English definitions
                        </span>
                    </div>
                    
                    <!-- Text Segment containing words wrapped dynamically -->
                    <article id="passage-container" class="serif-font text-lg leading-relaxed text-slate-700 space-y-6">
                        <p>
                            Last summer, I decided to <span class="vocab-word" data-word="enroll in">enroll in</span> a gardening and <span class="vocab-word" data-word="craft">craft</span> camp. It was an <span class="vocab-word" data-word="ancient">ancient</span> tradition at our school, and I was <span class="vocab-word" data-word="curious">curious</span> about it. My <span class="vocab-word" data-word="goal">goal</span> was to learn something new and make <span class="vocab-word" data-word="progress">progress</span>, not just in skills but also in <span class="vocab-word" data-word="bravery">bravery</span>. On the first day, our teacher asked us to <span class="vocab-word" data-word="discuss">discuss</span> our <span class="vocab-word" data-word="feelings">feelings</span> about the camp. I felt <span class="vocab-word" data-word="excitedly">excitedly</span> nervous.
                        </p>
                        <p>
                            Our first <span class="vocab-word" data-word="challenge">challenge</span> was to <span class="vocab-word" data-word="grow">grow</span> vegetables. We planted <span class="vocab-word" data-word="cabbage">cabbage</span> seeds and used a special <span class="vocab-word" data-word="machine">machine</span> to <span class="vocab-word" data-word="mix">mix</span> the soil. We had to <span class="vocab-word" data-word="separate">separate</span> the seeds into different <span class="vocab-word" data-word="sorts">sorts</span> in <span class="vocab-word" data-word="square">square</span> boxes. We also learned to <span class="vocab-word" data-word="store">store</span> water in a tank under the <span class="vocab-word" data-word="roof">roof</span>. <span class="vocab-word" data-word="everywhere">Everywhere</span> we looked, there were pots and tools. One day, we used a 3D <span class="vocab-word" data-word="print">print</span>er to print small <span class="vocab-word" data-word="models">models</span> of plants. It was <span class="vocab-word" data-word="impossible">impossible</span> to do it perfectly at first, but we didn’t <span class="vocab-word" data-word="fail">fail</span>. We kept trying.
                        </p>
                        <p>
                            We also made <span class="vocab-word" data-word="pizza">pizza</span> in an outdoor oven. We added different <span class="vocab-word" data-word="flavours">flavours</span> like herbs and cheese. The dough became <span class="vocab-word" data-word="sticky">sticky</span>, and I accidentally got some on my <span class="vocab-word" data-word="cloth">cloth</span> apron. We used <span class="vocab-word" data-word="cotton">cotton</span> gloves to <span class="vocab-word" data-word="handle">handle</span> the hot pan. Once, my friend <span class="vocab-word" data-word="burned">burned</span> his finger on the oven. <span class="vocab-word" data-word="luckily">Luckily</span>, it was a minor <span class="vocab-word" data-word="burn">burn</span>, and we had a first-aid kit. He stuck a <span class="vocab-word" data-word="sticker">sticker</span> on his bandage to feel better.
                        </p>
                        <p>
                            For <span class="vocab-word" data-word="windsurf">windsurf</span> practice, we went to a nearby lake. I had to <span class="vocab-word" data-word="skate">skate</span> on the board and <span class="vocab-word" data-word="stick">stick</span> to the handle tightly. The <span class="vocab-word" data-word="handle">handle</span> of the sail was heavy. I <span class="vocab-word" data-word="improved">improved</span> my balance day by day. We also had to <span class="vocab-word" data-word="test">test</span> our equipment <span class="vocab-word" data-word="everywhere">everywhere</span> on the water. It was a great <span class="vocab-word" data-word="experience">experience</span>. We faced many <span class="vocab-word" data-word="difficulties">difficulties</span>, but we learned to <span class="vocab-word" data-word="solve">solve</span> them. Our teacher always <span class="vocab-word" data-word="reminded">reminded</span> us to stay positive. <span class="vocab-word" data-word="hopefully">Hopefully</span>, we would all <span class="vocab-word" data-word="succeed">succeed</span>.
                        </p>
                        <p>
                            At the end, we presented our projects. I felt <span class="vocab-word" data-word="proud">proud</span>—maybe even the <span class="vocab-word" data-word="proudest">proudest</span>—when I showed my vegetable garden. My classmate, a fifth <span class="vocab-word" data-word="grader">grader</span>, made a beautiful <span class="vocab-word" data-word="magazine">magazine</span> about our camp life. Another friend created a creative <span class="vocab-word" data-word="solution">solution</span> for watering plants using recycled bottles. We all received a certificate of <span class="vocab-word" data-word="success">success</span>. Our teacher said our teamwork was <span class="vocab-word" data-word="basic">basic</span> to our achievements.
                        </p>
                        <p>
                            This camp taught me that <span class="vocab-word" data-word="bravery">bravery</span> comes from trying new things. <span class="vocab-word" data-word="curiosity">Curiosity</span> led to <span class="vocab-word" data-word="countless">countless</span> discoveries. We used <span class="vocab-word" data-word="traffic">traffic</span> rules to stay safe on the paths. We even learned that this camp <span class="vocab-word" data-word="came into being">came into being</span> thanks to a generous donation. On the last day, I took my <span class="vocab-word" data-word="umbrella">umbrella</span> and walked <span class="vocab-word" data-word="away">away</span> from the camp, carrying countless happy memories and a sticky bag of homemade jam. It was a <span class="vocab-word" data-word="course">course</span> in life, not just in gardening. I will never forget it.
                        </p>
                    </article>
                </div>

                <!-- Right Side: Sidebar Live Word Inspector -->
                <div class="lg:col-span-4 flex flex-col gap-6">
                    <div class="bg-gradient-to-br from-indigo-50 to-slate-100 rounded-2xl p-6 border border-indigo-100 sticky top-24 shadow-sm">
                        <div id="inspector-placeholder" class="text-center py-12 flex flex-col items-center justify-center gap-4">
                            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm text-indigo-500">
                                <i class="fa-solid fa-hand-pointer text-2xl animate-bounce"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-slate-700">Vocabulary Inspector</h3>
                                <p class="text-slate-500 text-sm mt-1 max-w-xs">Click any highlighted green word inside the passage to inspect its English definitions and examples!</p>
                            </div>
                        </div>

                        <!-- Active Word Inspector Pane -->
                        <div id="inspector-active" class="hidden flex flex-col">
                            <div class="flex items-start justify-between mb-4">
                                <div>
                                    <h3 id="inspect-word" class="text-2xl font-bold text-indigo-900 tracking-tight">word</h3>
                                    <div class="flex flex-wrap gap-2 mt-2">
                                        <span id="inspect-pos" class="bg-teal-100 text-teal-800 text-xs px-2 py-0.5 rounded-md font-bold uppercase">pos</span>
                                        <button onclick="speakSelectedWord()" class="hover:bg-slate-200/80 p-1.5 rounded-full transition text-indigo-700" title="Listen Pronunciation">
                                            <i class="fa-solid fa-volume-high"></i>
                                        </button>
                                    </div>
                                </div>
                                <button onclick="toggleWordMasteryFromInspector()" id="inspect-master-btn" class="flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border transition-all shadow-sm">
                                    <i class="fa-solid fa-check-circle"></i> <span>Mastered</span>
                                </button>
                            </div>

                            <div class="space-y-4 text-sm">
                                <div>
                                    <h4 class="text-slate-400 font-bold uppercase tracking-wider text-xs">Definition (English)</h4>
                                    <p id="inspect-definition" class="text-slate-700 font-medium mt-1 leading-relaxed bg-white p-3 rounded-xl border border-slate-200/50">To be successful in achieving your goals.</p>
                                </div>

                                <div id="inspect-derivatives-wrapper">
                                    <h4 class="text-slate-400 font-bold uppercase tracking-wider text-xs">Derivatives & Forms</h4>
                                    <p id="inspect-derivatives" class="text-indigo-800 font-semibold mt-1">success (n.), successful (adj.)</p>
                                </div>

                                <div>
                                    <h4 class="text-slate-400 font-bold uppercase tracking-wider text-xs">Context Sentence from Passage</h4>
                                    <p id="inspect-sentence" class="text-slate-600 italic mt-1 leading-relaxed border-l-2 border-teal-500 pl-3">"Hopefully, we would all succeed."</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ==================== TAB: SMART FLASHCARDS ==================== -->
        <section id="tab-content-flashcards" class="tab-pane hidden">
            <div class="max-w-xl mx-auto flex flex-col items-center">
                
                <!-- Deck Controls and Progress bar -->
                <div class="w-full flex items-center justify-between mb-4 px-2">
                    <div class="flex items-center gap-2">
                        <span class="text-sm font-bold text-slate-500">Filters:</span>
                        <select onchange="filterFlashcardDeck(this.value)" class="text-xs bg-white border border-slate-300 rounded-lg py-1 px-2.5 font-semibold text-slate-700 outline-none focus:ring-1 focus:ring-indigo-500">
                            <option value="all">Show All Words (58)</option>
                            <option value="needs_review">Needs Review</option>
                            <option value="mastered">Mastered Only</option>
                        </select>
                    </div>
                    <span id="deck-progress-indicator" class="text-xs font-bold text-indigo-700 bg-indigo-50 px-2.5 py-1 rounded-full">Card 1 / 58</span>
                </div>

                <!-- 3D Flippable Card Base Container -->
                <div class="flashcard-perspective w-full h-80 sm:h-96 relative cursor-pointer" onclick="flipFlashcard()">
                    <div id="flashcard-inner" class="flashcard-inner w-full h-full absolute rounded-2xl shadow-lg border border-slate-200/80 bg-white">
                        
                        <!-- Front View of Flashcard -->
                        <div class="flashcard-front absolute inset-0 p-6 flex flex-col justify-between rounded-2xl bg-gradient-to-br from-white to-slate-50">
                            <div class="flex items-center justify-between">
                                <span id="card-pos-front" class="bg-indigo-100 text-indigo-800 text-xs px-2.5 py-1 rounded-full font-bold uppercase">POS</span>
                                <div class="flex items-center gap-2">
                                    <button onclick="speakCardFront(event)" class="text-slate-400 hover:text-indigo-600 transition p-2 hover:bg-slate-100 rounded-full" title="Hear Pronunciation">
                                        <i class="fa-solid fa-volume-high text-lg"></i>
                                    </button>
                                    <span id="card-status-badge" class="text-xs font-bold bg-amber-50 text-amber-700 px-2.5 py-1 rounded-full">
                                        <i class="fa-solid fa-star mr-1"></i> Studying
                                    </span>
                                </div>
                            </div>

                            <div class="text-center my-auto">
                                <h3 id="card-word-front" class="text-4xl sm:text-5xl font-extrabold text-slate-800 tracking-tight select-none">brave</h3>
                                <p id="card-forms-front" class="text-xs text-indigo-600 font-bold uppercase tracking-widest mt-3">Related Forms: bravery</p>
                            </div>

                            <div class="text-center border-t border-slate-100 pt-4 flex flex-col items-center">
                                <p class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-1">Passage Hints</p>
                                <p id="card-hint-front" class="text-slate-500 text-xs italic select-none">"not just in skills but also in bravery."</p>
                            </div>
                        </div>

                        <!-- Back View of Flashcard -->
                        <div class="flashcard-back absolute inset-0 p-6 flex flex-col justify-between rounded-2xl bg-slate-900 text-white">
                            <div class="flex items-center justify-between">
                                <span class="bg-teal-500/20 text-teal-300 text-xs px-2.5 py-1 rounded-full font-bold uppercase tracking-wider">English Definition</span>
                                <i class="fa-solid fa-spell-check text-teal-400 text-lg"></i>
                            </div>

                            <!-- English-to-English Definition, strictly no Chinese -->
                            <div class="my-auto text-center px-4 space-y-4">
                                <p id="card-word-back" class="text-2xl font-bold text-teal-300">brave</p>
                                <p id="card-def-back" class="text-base sm:text-lg text-slate-100 font-medium leading-relaxed">Showing no fear of dangerous situations.</p>
                                <p id="card-forms-back" class="text-xs text-slate-400 font-semibold italic">Noun form: bravery</p>
                            </div>

                            <div class="text-center text-slate-400 text-xs border-t border-slate-800 pt-4">
                                <i class="fa-solid fa-arrows-rotate mr-1"></i> Click to flip back
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Carousel Mechanics and Study Action Bar -->
                <div class="flex items-center justify-between gap-4 mt-6 w-full px-2">
                    <button onclick="prevFlashcard()" class="w-12 h-12 bg-white rounded-xl shadow-md border border-slate-200 text-slate-700 hover:bg-slate-50 transition flex items-center justify-center">
                        <i class="fa-solid fa-chevron-left text-lg"></i>
                    </button>

                    <div class="flex items-center gap-3 flex-grow max-w-xs">
                        <button onclick="markCurrentCardStatus(false)" id="action-btn-again" class="flex-1 py-3 px-4 bg-rose-50 hover:bg-rose-100 border border-rose-200 text-rose-700 rounded-xl transition font-bold text-xs flex flex-col sm:flex-row items-center justify-center gap-1.5 shadow-sm">
                            <i class="fa-solid fa-arrows-rotate"></i> Study Again
                        </button>
                        <button onclick="markCurrentCardStatus(true)" id="action-btn-master" class="flex-1 py-3 px-4 bg-teal-50 hover:bg-teal-100 border border-teal-200 text-teal-800 rounded-xl transition font-bold text-xs flex flex-col sm:flex-row items-center justify-center gap-1.5 shadow-sm">
                            <i class="fa-solid fa-circle-check"></i> I Know It!
                        </button>
                    </div>

                    <button onclick="nextFlashcard()" class="w-12 h-12 bg-white rounded-xl shadow-md border border-slate-200 text-slate-700 hover:bg-slate-50 transition flex items-center justify-center">
                        <i class="fa-solid fa-chevron-right text-lg"></i>
                    </button>
                </div>

                <button onclick="shuffleFlashcardDeck()" class="mt-4 text-xs font-bold text-indigo-600 hover:text-indigo-800 transition flex items-center gap-1.5">
                    <i class="fa-solid fa-shuffle"></i> Shuffle Study Deck
                </button>
            </div>
        </section>

        <!-- ==================== TAB: DICTIONARY LIST ==================== -->
        <section id="tab-content-dictionary" class="tab-pane hidden">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200/60 flex flex-col gap-6">
                <div class="flex flex-col md:flex-row items-stretch md:items-center justify-between gap-4 border-b border-slate-100 pb-5">
                    <div>
                        <h2 class="text-xl font-bold text-slate-800">Visual Lexicon Dictionary</h2>
                        <p class="text-xs text-slate-500 mt-1">Study all 58 vital vocabulary terms, track mastery, and listen to spoken definitions.</p>
                    </div>
                    
                    <!-- Search Input and Quick Filtering Pill Options -->
                    <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                        <div class="relative flex-grow sm:w-64">
                            <input type="text" id="dict-search-input" oninput="searchVocabularyDictionary()" placeholder="Search word or derivative..." class="w-full bg-slate-50 border border-slate-300 rounded-xl py-2 pl-9 pr-4 text-sm font-medium outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white transition-all">
                            <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-3 text-slate-400 text-sm"></i>
                        </div>
                        <select id="dict-filter-pos" onchange="searchVocabularyDictionary()" class="bg-slate-50 border border-slate-300 rounded-xl py-2 px-3 text-sm font-semibold text-slate-700 outline-none focus:ring-2 focus:ring-indigo-500 transition-all">
                            <option value="all">All Parts of Speech</option>
                            <option value="verb">Verbs</option>
                            <option value="noun">Nouns</option>
                            <option value="adjective">Adjectives</option>
                            <option value="adverb">Adverbs</option>
                            <option value="phrase">Phrases / Conjunctions</option>
                        </select>
                    </div>
                </div>

                <!-- Dictionary Terms Grid Container -->
                <div id="dictionary-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <!-- Cards injected dynamically here -->
                </div>
            </div>
        </section>

        <!-- ==================== TAB: CLOZE QUIZ CHALLENGE ==================== -->
        <section id="tab-content-quiz" class="tab-pane hidden">
            <div class="max-w-3xl mx-auto bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-slate-200/60">
                <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-6">
                    <div>
                        <h2 class="text-xl font-bold text-slate-800">Contextual Vocabulary Cloze Quiz</h2>
                        <p class="text-xs text-slate-500 mt-1">Practice using correct forms and word variants in the exact contextual sentences from your lesson.</p>
                    </div>
                    <button onclick="resetQuiz()" class="text-xs font-bold text-slate-500 hover:text-indigo-600 transition flex items-center gap-1.5 bg-slate-100 px-3 py-1.5 rounded-lg">
                        <i class="fa-solid fa-rotate-left"></i> Reset Quiz
                    </button>
                </div>

                <!-- Interactive Quiz Segment -->
                <div id="quiz-questions-stack" class="space-y-6">
                    <!-- Dynamic forms inserted via JS -->
                </div>

                <div class="mt-8 pt-6 border-t border-slate-100 flex justify-between items-center">
                    <div class="text-slate-500 text-sm font-semibold">
                        Overall Score: <span id="quiz-score-indicator" class="text-indigo-600 font-extrabold">0 / 12 Correct</span>
                    </div>
                    <button onclick="checkAllQuizAnswers()" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-6 rounded-xl transition text-sm shadow-md shadow-indigo-600/10">
                        Submit & Review Answers
                    </button>
                </div>
            </div>
        </section>

    </main>

    <!-- Footer of the system -->
